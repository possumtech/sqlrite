{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"rules": {
			"complexity": {
				"noStaticOnlyClass": "off"
			},
			"correctness": {
				"noConstructorReturn": "off"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"includes": ["**/*.js", "**/*.json"]
	}
}
